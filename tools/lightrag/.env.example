# ════════════════════════════════════════════════════════════════
# LightRAG Plus - Configuration Template
# Copy this file to .env and fill in your API keys
# ════════════════════════════════════════════════════════════════

# ════════════════════════════════════════════════════════════════
# EMBEDDING PROVIDER — choose based on your content type
# ════════════════════════════════════════════════════════════════
#
#   openai  → TEXT ONLY (PDFs, markdown, plain text)
#             Cheaper, faster, simpler. Use this for most cases.
#
#   gemini  → MULTIMODAL (text + images + video + audio)
#             Required if you want LightRAG to process non-text files.
#             Costs more; only enable when you need multimodal search.
#
# Rule of thumb:
#   Feeding only documents/text?  → EMBEDDING_PROVIDER=openai
#   Feeding images/video/audio?   → EMBEDDING_PROVIDER=gemini
#
EMBEDDING_PROVIDER=openai

# ────────────────────────────────────────────────────────────────
# OpenAI Configuration (TEXT ONLY)
# ────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your-openai-api-key-here
# text-embedding-3-small: 1536 dims, cost-effective (DEFAULT)
# text-embedding-3-large: 3072 dims, higher quality
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ────────────────────────────────────────────────────────────────
# Gemini Configuration (MULTIMODAL: text + images + video + audio)
# ────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here
# gemini-embedding-2-preview: 3072 dims, highest quality (DEFAULT)
# gemini-embedding-2: 768 dims, stable release
GEMINI_EMBEDDING_MODEL=gemini-embedding-2-preview

# ────────────────────────────────────────────────────────────────
# Optional: Override auto-detected dimension
# ────────────────────────────────────────────────────────────────
# EMBEDDING_DIM=1536

# ════════════════════════════════════════════════════════════════
# VECTOR BACKENDS (Optional - can enable BOTH simultaneously)
# ════════════════════════════════════════════════════════════════
# Local nano-vectordb is ALWAYS active (LightRAG core)
# Enable Supabase and/or Pinecone to mirror embeddings to remote backends
ENABLE_SUPABASE=false
ENABLE_PINECONE=false

# ────────────────────────────────────────────────────────────────
# Supabase Configuration (if ENABLE_SUPABASE=true)
# ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-role-key
# Management API token — required for provision.py auto-schema deployment
# Get at: supabase.com → Account (top-right) → Access Tokens
SUPABASE_MANAGEMENT_TOKEN=your-supabase-management-token-here

# ────────────────────────────────────────────────────────────────
# Pinecone Configuration (if ENABLE_PINECONE=true)
# ────────────────────────────────────────────────────────────────
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX=lightrag-vectors
PINECONE_ENVIRONMENT=us-east-1-aws

# ════════════════════════════════════════════════════════════════
# MULTIMODAL PROCESSING
# ════════════════════════════════════════════════════════════════
# simple:   Text extraction only (OCR/transcription)
#           Works with both OpenAI and Gemini
#           All content goes through LightRAG graph
#
# advanced: Text extraction + raw multimodal embeddings
#           REQUIRES EMBEDDING_PROVIDER=gemini
#           Text → LightRAG graph
#           Raw images/video/audio → Supabase/Pinecone only
MULTIMODAL_MODE=simple

# ════════════════════════════════════════════════════════════════
# LIGHTRAG CORE SETTINGS — vars read by lightrag-hku server
# ════════════════════════════════════════════════════════════════

# LLM — local Ollama (free, private, no API key)
# Requires: winget install Ollama.Ollama + ollama pull llama3.2
LLM_BINDING=ollama
LLM_MODEL=llama3.2
LLM_BINDING_HOST=http://localhost:11434

# Embedding — OpenAI (text only; switch EMBEDDING_BINDING=gemini for multimodal)
EMBEDDING_BINDING=openai
# CRITICAL: must be set explicitly — otherwise LLM_BINDING_HOST bleeds in and causes 404 errors
EMBEDDING_BINDING_HOST=https://api.openai.com/v1
EMBEDDING_BINDING_API_KEY=your-openai-api-key-here
EMBEDDING_MODEL=text-embedding-3-small

LIGHTRAG_WORKING_DIR=./rag_storage

# ════════════════════════════════════════════════════════════════
# LIGHTRAG API SERVER (for Web UI)
# ════════════════════════════════════════════════════════════════
HOST=0.0.0.0
PORT=9621

# Authentication (optional - leave empty for guest mode)
TOKEN_SECRET=
AUTH_ACCOUNTS=
