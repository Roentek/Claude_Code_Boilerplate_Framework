# LightRAG Server Configuration Template
# Copy this file to .env and fill in your API key

# OpenAI API Key (required for LLM and embeddings)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# Server settings
HOST=0.0.0.0
PORT=9621

# LLM Configuration - Use OpenAI
LLM_BINDING=openai
LLM_MODEL=gpt-4o-mini

# Embedding Configuration - Use OpenAI
EMBEDDING_BINDING=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# Authentication (optional - leave empty for guest mode)
TOKEN_SECRET=
AUTH_ACCOUNTS=

# Alternative LLM Providers (comment out OpenAI settings above and uncomment one below)
# ──────────────────────────────────────────────────────────────────────────────
# Anthropic Claude
# LLM_BINDING=anthropic
# ANTHROPIC_API_KEY=your-anthropic-key-here

# Google Gemini
# LLM_BINDING=gemini
# GEMINI_API_KEY=your-gemini-key-here

# Local Ollama
# LLM_BINDING=ollama
# OLLAMA_HOST=http://localhost:11434
