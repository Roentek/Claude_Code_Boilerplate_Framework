{
  "__readme": "Copy this file to .claude/settings.local.json (already gitignored). Fill in credentials only for the MCP servers you plan to use — leave the rest empty or delete unused keys. Restart Claude Code after saving. Never commit settings.local.json.",

  "__activation_guide": {
    "memory":               "NO KEY NEEDED — activates automatically. Requires npx in PATH.",
    "supabase-mcp":         "SUPABASE_API_PAT — supabase.com → Account → Access Tokens → Generate new token (all scopes).",
    "openrouter-mcp":       "OPENROUTER_API_KEY — openrouter.ai → Keys → Create Key.",
    "kie-ai":               "KIE_AI_API_KEY — kie.ai → Dashboard → API Keys.",
    "tavily-mcp":           "TAVILY_API_KEY — tavily.com → Dashboard → API Key (free tier available).",
    "google-workspace-mcp": "GOOGLE_OAUTH_CLIENT_ID + GOOGLE_OAUTH_CLIENT_SECRET + GOOGLE_USER_EMAIL — (1) console.cloud.google.com → new project; (2) enable Gmail/Drive/Sheets/Calendar/Docs APIs; (3) APIs & Services → Credentials → Create OAuth 2.0 Client ID (Desktop app type) → copy Client ID + Secret below; (4) First use opens a browser OAuth consent window.",
    "trigger":              "NO KEY NEEDED — authenticates via Trigger.dev CLI. Run once: npx trigger.dev@latest login",
    "pinecone-mcp":         "PINECONE_API_KEY — app.pinecone.io → API Keys → Create API Key.",
    "vapi-mcp":             "VAPI_API_TOKEN — dashboard.vapi.ai → Account → Developer → API Keys.",
    "alpaca":               "ALPACA_API_KEY + ALPACA_SECRET_KEY — alpaca.markets → Paper Trading → API Keys (free paper keys, no real money at risk). NOTE: ALPACA_PAPER_TRADE=true is already hardcoded in .mcp.json.",
    "n8n-mcp":              "N8N_HOST_URL (your n8n instance URL, e.g. https://n8n.example.com) + N8N_API_KEY — in n8n UI: Settings → API → Create API Key.",
    "apify":                "APIFY_API_PAT — console.apify.com → Settings → Integrations → Personal API Tokens → Create token.",
    "zep-mcp":              "NO KEY NEEDED — connects to the public Zep docs endpoint. Activates automatically.",
    "canva-dev":            "NO KEY NEEDED — browser OAuth via @canva/cli. A browser window opens automatically on first use.",
    "monet-mcp":            "MONET_API_KEY — monet.design/mcp → Get API Key.",
    "stitch":               "STITCH_API_KEY — stitch.withgoogle.com → Settings → API Key.",
    "21st-dev-magic":       "TWENTYFIRST_DEV_API_KEY — 21st.dev/magic/console → API Keys. Free tier includes Inspiration Search + SVG Icon Search. Magic Generate requires Pro ($20/mo).",
    "higgsfield":           "NO KEY NEEDED — browser OAuth on first use at higgsfield.ai. The MCP server connects to https://mcp.higgsfield.ai/mcp automatically.",
    "playwright-mcp":       "NO KEY NEEDED — activates automatically. CLI (node tools/playwright.js) is always the primary tool; use this MCP only for interactive/multi-step sessions.",
    "firecrawl-mcp":        "FIRECRAWL_API_KEY — firecrawl.dev/app/api-keys → Create API Key (free tier available). CLI (firecrawl) is always the primary tool; use this MCP only for batch scraping or schema extraction.",
    "notebooklm-mcp":       "NO KEY NEEDED (uses cookie auth via nlm login). CLI (nlm) is always the primary tool; use this MCP only for complex multi-source research workflows.",
    "openspace":            "OPENSPACE_API_KEY (optional) — open-space.cloud → Register → Get API Key. Local features (task execution, evolution, local skill search) work without it. Cloud features (skill upload/download, cloud search) require the key. Also set OPENSPACE_HOST_SKILL_DIRS (your agent's skill directory, auto-detected from Claude Code) and OPENSPACE_WORKSPACE (path to tools/openspace).",
    "github@claude-plugins-official": "GITHUB_PERSONAL_ACCESS_TOKEN — github.com → Settings → Developer settings → Personal access tokens → Fine-grained or classic token with 'repo' and 'read:org' scopes.",
    "cc-gemini-plugin@cc-gemini-plugin": "GEMINI_API_KEY — aistudio.google.com → Get API Key → Create API key in new project. Free tier available.",
    "context7":                          "CONTEXT7_API_KEY — context7.com → Account → API Keys. Used for live SDK/library documentation lookups via the context7 MCP server.",
    "memory-shrunk":                     "NO KEY NEEDED — wraps the memory MCP server with caveman-shrink proxy to compress tool descriptions. Reduces context overhead by ~50% for MCP metadata. CAVEMAN_SHRINK_FIELDS controls which fields to compress (default: description). CAVEMAN_SHRINK_DEBUG=1 enables debug logging.",
    "caveman@caveman":                   "NO KEY NEEDED — 75% token reduction on Claude responses. Commands: /caveman (activate), /caveman-commit (terse commits), /caveman-review (single-line PR comments), /caveman-stats (session token analysis), /caveman-compress (shrink memory files by 46%), /cavecrew (compressed subagents). CAVEMAN_STATUSLINE_SAVINGS=1 shows lifetime token savings in statusline.",

    "__note_cli_tools": "The keys below are for global CLI tools installed by setup.sh (codex-cli, gemini-cli). These run locally via Bash, not through MCP servers. Set them here AND in .env so both Claude Code and local shell scripts can access them.",
    "codex-cli (three-brain)":  "OPENAI_API_KEY — platform.openai.com → API Keys → Create new secret key. Required by codex-cli for /three-brain review/rescue routes and codex plugin.",
    "gemini-cli (three-brain)": "GEMINI_API_KEY — aistudio.google.com/apikey → Create API key in new project. Required by gemini-cli for /three-brain multimodal/long-context routes. Free tier available. NOTE: This is the same key used by cc-gemini-plugin above.",

    "__note_app_code_vars": "The keys below are used by YOUR application code (Trigger.dev tasks, Python tools) via dotenv — not by MCP servers directly. Set them here if you want Claude Code subprocesses to inherit them; otherwise setting them in .env only is sufficient.",
    "SUPABASE_PROJECT_URL": "SUPABASE_PROJECT_URL — Supabase dashboard → Project Settings → API → Project URL (e.g. https://xyzabc.supabase.co). Used by Supabase JS SDK in app code.",
    "SUPABASE_PROJECT_KEY": "SUPABASE_PROJECT_KEY — Supabase dashboard → Project Settings → API → anon/public or service_role key. Used by Supabase JS SDK in app code.",  
    "VAPI_SDK_KEY":         "VAPI_SDK_KEY — dashboard.vapi.ai → Account → Developer → Public Key. Client-facing SDK key used by app code; distinct from VAPI_API_TOKEN used by vapi-mcp.",
    "ALPACA_BASE_URL":      "ALPACA_BASE_URL — paper: https://paper-api.alpaca.markets/v2 · live: https://api.alpaca.markets. NOTE: The alpaca MCP has paper mode hardcoded in .mcp.json — this var is for app code only.",
    "OPENROUTER_BASE_URL":  "OPENROUTER_BASE_URL — always https://openrouter.ai/api/v1. Needed by app code that calls OpenRouter directly.",
    "OPENROUTER_MODEL":     "OPENROUTER_MODEL — model slug from openrouter.ai/models (e.g. openrouter/auto, openai/gpt-4o, anthropic/claude-sonnet-4). Used by app code for model selection.",
    "OPENROUTER_MODEL":     "e.g. openrouter/auto" — Openrouter Auto (model select)           
    "OPENROUTER_MODEL":     "e.g. openrouter/free" — OpenRouter Free (free tier)    

    "__note_model_switching": "OPTIONAL — Route Claude Code itself through a different model or provider. Leave all blank to use native Anthropic (default). To activate: set ANTHROPIC_BASE_URL + ANTHROPIC_AUTH_TOKEN + ANTHROPIC_API_KEY='' and choose an ANTHROPIC_MODEL slug below.",
    "ANTHROPIC_BASE_URL":               "Set to https://openrouter.ai/api/v1 to route Claude Code through OpenRouter. Leave blank for native Anthropic.",
    "ANTHROPIC_AUTH_TOKEN":             "Your OpenRouter API key (same value as OPENROUTER_API_KEY). Claude Code uses this instead of ANTHROPIC_API_KEY when ANTHROPIC_BASE_URL is set to OpenRouter.",
    "ANTHROPIC_API_KEY":                "Set to empty string '' when routing through OpenRouter — this prevents Claude Code from using a native Anthropic key at the same time.",
    "ANTHROPIC_MODEL":                  "Primary model slug for Claude Code. Available options: openrouter/auto (default, picks best) · openrouter/free (free tier) · openai/gpt-4o · openai/gpt-4o-mini · anthropic/claude-opus-4 · anthropic/claude-opus-4-5 · anthropic/claude-sonnet-4 · anthropic/claude-sonnet-4-5 · google/gemini-2.0-flash-thinking-exp:free · meta-llama/llama-3.3-70b-instruct · deepseek/deepseek-chat",
    "ANTHROPIC_DEFAULT_SONNET_MODEL":   "Override the model used when skills/subagents request a Sonnet-class model. Set to any model slug above.",
    "ANTHROPIC_DEFAULT_OPUS_MODEL":     "Override the model used when skills/subagents request an Opus-class model. Set to any model slug above.",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL":    "Override the model used for fast/cheap Haiku-class tasks. Set to any model slug above.",
    "ANTHROPIC_SMALL_FAST_MODEL":       "Override model for internal quick-turnaround sub-tasks (e.g. tool-call routing). Set to any model slug above.",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "Set to '1' to enable experimental multi-agent team support in Claude Code (parallel subagent spawning).",
    "CLAUDE_CODE_SUBAGENT_MODEL":       "Override the model used for Claude Code subagents / parallel agent dispatches. Set to any model slug above."
  },

