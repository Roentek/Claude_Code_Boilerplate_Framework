{
  "__readme": "Copy this file to .claude/settings.local.json (already gitignored). Fill in credentials only for the MCP servers you plan to use — leave the rest empty or delete unused keys. Restart Claude Code after saving. Never commit settings.local.json.",

  "__activation_guide": {
    "memory":               "NO KEY NEEDED — activates automatically. Requires npx in PATH.",
    "supabase-mcp":         "SUPABASE_API_PAT — supabase.com → Account → Access Tokens → Generate new token (all scopes).",
    "openrouter-mcp":       "OPENROUTER_API_KEY — openrouter.ai → Keys → Create Key.",
    "kie-ai":               "KIE_AI_API_KEY — kie.ai → Dashboard → API Keys.",
    "tavily-mcp":           "TAVILY_API_KEY — tavily.com → Dashboard → API Key (free tier available).",
    "google-workspace-mcp": "GOOGLE_OAUTH_CLIENT_ID + GOOGLE_OAUTH_CLIENT_SECRET + GOOGLE_USER_EMAIL — (1) console.cloud.google.com → new project; (2) enable Gmail/Drive/Sheets/Calendar/Docs APIs; (3) APIs & Services → Credentials → Create OAuth 2.0 Client ID (Desktop app type) → copy Client ID + Secret below; (4) First use opens a browser OAuth consent window.",
    "trigger":              "NO KEY NEEDED — authenticates via Trigger.dev CLI. Run once: npx trigger.dev@latest login",
    "pinecone-mcp":         "PINECONE_API_KEY — app.pinecone.io → API Keys → Create API Key.",
    "vapi-mcp":             "VAPI_API_TOKEN — dashboard.vapi.ai → Account → Developer → API Keys.",
    "alpaca":               "ALPACA_API_KEY + ALPACA_SECRET_KEY — alpaca.markets → Paper Trading → API Keys (free paper keys, no real money at risk). NOTE: ALPACA_PAPER_TRADE=true is already hardcoded in .mcp.json.",
    "n8n-mcp":              "N8N_HOST_URL (your n8n instance URL, e.g. https://n8n.example.com) + N8N_API_KEY — in n8n UI: Settings → API → Create API Key.",
    "apify":                "APIFY_API_PAT — console.apify.com → Settings → Integrations → Personal API Tokens → Create token.",
    "zep-mcp":              "NO KEY NEEDED — connects to the public Zep docs endpoint. Activates automatically.",
    "canva-dev":            "NO KEY NEEDED — browser OAuth via @canva/cli. A browser window opens automatically on first use.",
    "monet-mcp":            "MONET_API_KEY — monet.design/mcp → Get API Key.",
    "stitch":               "STITCH_API_KEY — stitch.withgoogle.com → Settings → API Key."
  },

  "env": {
    "SUPABASE_API_PAT":           "",
    "OPENROUTER_API_KEY":         "",
    "KIE_AI_API_KEY":             "",
    "TAVILY_API_KEY":             "",
    "GOOGLE_OAUTH_CLIENT_ID":     "",
    "GOOGLE_OAUTH_CLIENT_SECRET": "",
    "GOOGLE_USER_EMAIL":          "",
    "PINECONE_API_KEY":           "",
    "VAPI_API_TOKEN":             "",
    "ALPACA_API_KEY":             "",
    "ALPACA_SECRET_KEY":          "",
    "N8N_HOST_URL":               "",
    "N8N_API_KEY":                "",
    "APIFY_API_PAT":              "",
    "MONET_API_KEY":              "",
    "STITCH_API_KEY":             ""
  },

