{
  "env": {},
  "permissions": {
    "allow": [
      "Bash(dir:*)",
      "Bash(ren:*)",
      "Bash(mv:*)",
      "Bash(grep:*)",
      "Bash(mkdir:*)",
      "Bash(exit)",
      "Bash(claude mcp add:*)",
      "Bash(claude --version)",
      "Bash(claude --debug)",
      "Bash(where npm)",
      "Bash(npm install *)",
      "Bash(npm cache clean:*)",
      "Bash(npm run:*)",
      "Bash(where n8n-mcp)",
      "Bash(npx n8n-mcp:*)",
      "Bash(git remote set-url:*)",
      "Bash(npx markdownlint-cli:*)",
      "Bash(python3 *)",
      "Bash(gh api *)",
      "Bash(npx skillui *)",
      "Bash(skillui *)",
      "Bash(python -m json.tool)",
      "Bash(gh repo *)",
      "Bash(start *)",
      "Bash(python *)",
      "Bash(node tools/playwright.js:*)",
      "Bash(npx playwright:*)",
      "Bash(npm run playwright:*)",
      "Bash(firecrawl:*)",
      "Bash(npx firecrawl-cli:*)",
      "Bash(nlm:*)",
      "Bash(uvx --from notebooklm-mcp-cli nlm:*)",
      "Bash(bash .claude/hooks/setup.sh)",
      "Bash(echo \"exit: $?\")",
      "Bash(git *)",
      "Bash(curl *)",
      "Bash(codex *)",
      "Bash(gemini *)",
      "Bash(uv *)",
      "Bash(cp *)",
      "PowerShell(codex *)",
      "PowerShell(gemini *)",
      "PowerShell(uv *)",
      "PowerShell(skillui *)",
      "PowerShell(npx skillui *)",
      "PowerShell(node tools/playwright.js *)",
      "PowerShell(npx playwright *)",
      "PowerShell(firecrawl *)",
      "PowerShell(npx firecrawl-cli *)",
      "PowerShell(nlm *)",
      "PowerShell(uvx --from notebooklm-mcp-cli nlm *)",
      "PowerShell(npm install *)",
      "PowerShell(Get-Process *)",
      "PowerShell(uv sync *)",
      "PowerShell(Move-Item *)",
      "PowerShell(Compare-Object *)"
    ],
    "deny": [],
    "defaultMode": "bypassPermissions"
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "memory",
    "supabase-mcp",
    "openrouter-mcp",
    "kie-ai",
    "tavily-mcp",
    "google-workspace-mcp",
    "trigger",
    "pinecone-mcp",
    "vapi-mcp",
    "alpaca",
    "n8n-mcp",
    "apify",
    "zep-mcp",
    "canva-dev",
    "monet-mcp",
    "stitch",
    "21st-dev-magic",
    "playwright-mcp",
    "firecrawl-mcp",
    "higgsfield",
    "context7",
    "notebooklm-mcp",
    "openspace"
  ],
  "hooks": {
    "Setup": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'dir=\"$(pwd)\"; while [ \"$dir\" != \"/\" ] && [ ! -f \"$dir/.claude/hooks/setup.sh\" ]; do dir=\"$(dirname \"$dir\")\"; done; if [ -f \"$dir/.claude/hooks/setup.sh\" ]; then bash \"$dir/.claude/hooks/setup.sh\"; fi'",
            "statusMessage": "Running first-time project setup..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'dir=\"$(pwd)\"; while [ \"$dir\" != \"/\" ] && [ ! -f \"$dir/.claude/hooks/read-guard.sh\" ]; do dir=\"$(dirname \"$dir\")\"; done; if [ -f \"$dir/.claude/hooks/read-guard.sh\" ]; then bash \"$dir/.claude/hooks/read-guard.sh\"; fi'",
            "statusMessage": "Checking read scope..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'dir=\"$(pwd)\"; while [ \"$dir\" != \"/\" ] && [ ! -f \"$dir/.claude/hooks/autosync-docs.sh\" ]; do dir=\"$(dirname \"$dir\")\"; done; if [ -f \"$dir/.claude/hooks/autosync-docs.sh\" ]; then bash \"$dir/.claude/hooks/autosync-docs.sh\"; fi'",
            "statusMessage": "Checking if docs need updating..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'dir=\"$(pwd)\"; while [ \"$dir\" != \"/\" ] && [ ! -f \"$dir/.claude/hooks/stop.sh\" ]; do dir=\"$(dirname \"$dir\")\"; done; if [ -f \"$dir/.claude/hooks/stop.sh\" ]; then bash \"$dir/.claude/hooks/stop.sh\"; fi'"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "python -X utf8 .claude/scripts/context-monitor.py"
  },
  "enabledPlugins": {
    "agent-sdk-dev@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "pinecone@claude-plugins-official": false,
    "playground@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": false,
    "supabase@claude-plugins-official": false,
    "superpowers@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "ui-ux-pro-max@ui-ux-pro-max-skill": true,
    "andrej-karpathy-skills@karpathy-skills": true,
    "codex@openai-codex": true,
    "impeccable@impeccable": true,
    "cc-gemini-plugin@cc-gemini-plugin": true,
    "cli-anything@cli-anything": true,
    "apify-ultimate-scraper@apify-agent-skills": true
  },
  "extraKnownMarketplaces": {
    "claude-code-plugins": {
      "source": {
        "source": "git",
        "url": "https://github.com/anthropics/claude-code.git"
      }
    },
    "ui-ux-pro-max-skill": {
      "source": {
        "source": "git",
        "url": "https://github.com/nextlevelbuilder/ui-ux-pro-max-skill.git"
      },
      "autoUpdate": true
    },
    "karpathy-skills": {
      "source": {
        "source": "github",
        "repo": "forrestchang/andrej-karpathy-skills"
      },
      "autoUpdate": true
    },
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      },
      "autoUpdate": true
    },
    "impeccable": {
      "source": {
        "source": "github",
        "repo": "pbakaus/impeccable"
      },
      "autoUpdate": true
    },
    "cc-gemini-plugin": {
      "source": {
        "source": "github",
        "repo": "thepushkarp/cc-gemini-plugin"
      },
      "autoUpdate": true
    },
    "cli-anything": {
      "source": {
        "source": "github",
        "repo": "HKUDS/CLI-Anything"
      },
      "autoUpdate": true
    },
    "apify-agent-skills": {
      "source": {
        "source": "github",
        "repo": "apify/agent-skills"
      },
      "autoUpdate": true
    }
  }
}
