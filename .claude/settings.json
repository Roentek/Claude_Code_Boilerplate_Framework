{
  "permissions": {
    "allow": [
      "Bash(dir:*)",
      "Bash(ren:*)",
      "Bash(mv:*)",
      "Bash(grep:*)",
      "Bash(mkdir:*)",
      "Bash(exit)",
      "Bash(claude mcp add:*)",
      "Bash(claude --version)",
      "Bash(claude --debug)",
      "Bash(where npm)",
      "Bash(npm install:*)",
      "Bash(npm cache clean:*)",
      "Bash(npm run:*)",
      "Bash(where n8n-mcp)",
      "Bash(npx n8n-mcp:*)",
      "Bash(git remote set-url:*)",
      "Bash(npx markdownlint-cli:*)",
      "mcp__alpaca__get_stock_latest_trade",
      "mcp__claude_ai_Tavily__tavily_search",
      "mcp__claude_ai_Supabase__supabase_query",
      "mcp__claude_ai_OpenRouter__openrouter_query",
      "mcp__claude_ai_Spline__spline_query",
      "mcp__n8n-mcp__tools_documentation",
      "mcp__n8n-mcp__search_nodes",
      "mcp__n8n-mcp__get_node_essentials",
      "mcp__n8n-mcp__validate_workflow",
      "mcp__n8n-mcp__validate_workflow_connections",
      "mcp__n8n-mcp__get_node_documentation",
      "mcp__n8n-mcp__search_node_properties",
      "mcp__n8n-mcp__validate_node_operation",
      "mcp__n8n-mcp__get_node_for_task",
      "mcp__n8n-mcp__list_tasks",
      "mcp__zep-docs__search_documentation",
      "mcp__alpaca__get_stock_bars",
      "WebFetch(domain:docs.n8n.io)",
      "WebFetch(domain:help.getzep.com)",
      "WebFetch(domain:www.aitmpl.com)"
    ],
    "deny": [],
    "env": {}
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "memory",
    "supabase-mcp",
    "openrouter-mcp",
    "kie-ai",
    "tavily-mcp",
    "google-workspace-mcp",
    "trigger",
    "pinecone-mcp",
    "vapi-mcp",
    "alpaca",
    "n8n-mcp",
    "apify",
    "zep-mcp",
    "canva-dev",
    "monet-mcp"
  ],
  "hooks": {
    "Setup": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/scripts/setup.sh",
            "statusMessage": "Running first-time project setup..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/stop.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "python -X utf8 .claude/scripts/context-monitor.py"
  },
  "enabledPlugins": {
    "agent-sdk-dev@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "github@claude-plugins-official": false,
    "pinecone@claude-plugins-official": false,
    "playground@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": false,
    "supabase@claude-plugins-official": false,
    "superpowers@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "ui-ux-pro-max@ui-ux-pro-max-skill": true,
    "andrej-karpathy-skills@karpathy-skills": true
  },
  "extraKnownMarketplaces": {
    "claude-code-plugins": {
      "source": {
        "source": "git",
        "url": "https://github.com/anthropics/claude-code.git"
      }
    },
    "ui-ux-pro-max-skill": {
      "source": {
        "source": "git",
        "url": "https://github.com/nextlevelbuilder/ui-ux-pro-max-skill.git"
      },
      "autoUpdate": true
    },
    "karpathy-skills": {
      "source": {
        "source": "github",
        "repo": "forrestchang/andrej-karpathy-skills"
      },
      "autoUpdate": true
    }
  }
}
