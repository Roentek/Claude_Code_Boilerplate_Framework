{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "LightRAG Server",
      "type": "debugpy",
      "request": "launch",
      "module": "lightrag.api.lightrag_server",
      "args": [
        "--port", "9621",
        "--working-dir", "${workspaceFolder}/tools/lightrag/rag_storage"
      ],
      "cwd": "${workspaceFolder}/tools/lightrag",
      "env": {
        "PYTHONIOENCODING": "utf-8"
      },
      "envFile": "${workspaceFolder}/tools/lightrag/.env",
      "console": "integratedTerminal",
      "justMyCode": false,
      "python": "${workspaceFolder}/tools/lightrag/.venv/Scripts/python.exe",
      "serverReadyAction": {
        "pattern": "Uvicorn running on",
        "uriFormat": "http://localhost:9621",
        "action": "openExternally"
      }
    },
    {
      "name": "LightRAG Test Script",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/tools/lightrag/test_lightrag.py",
      "cwd": "${workspaceFolder}/tools/lightrag",
      "env": {
        "PYTHONIOENCODING": "utf-8"
      },
      "envFile": "${workspaceFolder}/tools/lightrag/.env",
      "console": "integratedTerminal",
      "justMyCode": false,
      "python": "${workspaceFolder}/tools/lightrag/.venv/Scripts/python.exe"
    },
    {
      "name": "OpenSpace Backend Server",
      "type": "debugpy",
      "request": "launch",
      "module": "openspace.dashboard_server",
      "args": [
        "--host", "127.0.0.1",
        "--port", "7788"
      ],
      "cwd": "${workspaceFolder}/tools/openspace",
      "env": {
        "PYTHONIOENCODING": "utf-8"
      },
      "console": "integratedTerminal",
      "justMyCode": false,
      "serverReadyAction": {
        "pattern": "Running on",
        "uriFormat": "http://127.0.0.1:7788",
        "action": "debugWithChrome"
      }
    },
    {
      "name": "OpenSpace Frontend",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "${workspaceFolder}/tools/openspace/frontend",
      "console": "integratedTerminal",
      "preLaunchTask": "OpenSpace: Check Frontend Dependencies",
      "serverReadyAction": {
        "pattern": "Local:.*http://127\\.0\\.0\\.1:(\\d+)",
        "uriFormat": "http://127.0.0.1:$1",
        "action": "openExternally"
      }
    }
  ],
  "compounds": [
    {
      "name": "OpenSpace Dashboard (Full Stack)",
      "configurations": [
        "OpenSpace Backend Server",
        "OpenSpace Frontend"
      ],
      "preLaunchTask": "OpenSpace: Check Frontend Dependencies",
      "presentation": {
        "hidden": false,
        "group": "openspace",
        "order": 1
      },
      "stopAll": true
    }
  ]
}
