# .env.example — Application Code Secrets Template
#
# Copy this file to .env and fill in your values.
#
# This file is for application code only (Trigger.dev tasks, Python tools, scripts
# that call dotenv.config() explicitly). It is NOT read by Claude Code or MCP servers.
#
# All Claude Code / MCP credentials are managed in .claude/settings.local.json.
# Copy .claude/settings.local.json.example → .claude/settings.local.json and fill in values.
#
# NEVER commit .env.

# ──────────────────────────────────────────────────────────────────────────────
# CLI TOOLS (local execution, not MCP)
# ──────────────────────────────────────────────────────────────────────────────
# These keys are required by global CLI tools installed by setup.sh.
# Also add them to .claude/settings.local.json → env block so Claude Code can
# access them when spawning subprocesses.

# OpenAI API Key — platform.openai.com → API Keys → Create new secret key
# Used by: codex-cli (three-brain skill review/rescue routes, codex plugin), lfightrag (optional LLM provider), cc-openai-plugin
OPENAI_API_KEY=

# Gemini API Key — aistudio.google.com/apikey → Create API key in new project
# Used by: gemini-cli (three-brain skill multimodal/long-context routes), cc-gemini-plugin, LightRAG
# Free tier available.
GEMINI_API_KEY=

# Anthropic API Key — console.anthropic.com → API Keys → Create Key
# Used by: LightRAG (optional LLM provider for Claude models)
ANTHROPIC_API_KEY=

# Ollama Host — local Ollama server (for offline LLM usage)
# Used by: LightRAG (optional local LLM provider)
# Install: ollama.ai → ollama serve
OLLAMA_HOST=http://localhost:11434

# OpenSpace — Self-evolving skill system (MCP server + CLI)
# Used by: openspace-mcp (MCP server), openspace CLI (standalone mode)
# Register at: open-space.cloud (optional — local features work without it)

# Skills directory (where Claude Code installs skills)
# AUTO-CONFIGURED by setup.sh — detects your platform and sets the correct path
# Unix/Mac/Git Bash: ~/.claude/skills
# Windows (PowerShell/CMD): %USERPROFILE%\.claude\skills or C:\Users\YourUsername\.claude\skills
# After running setup.sh, this will be set to your actual home directory path
OPENSPACE_HOST_SKILL_DIRS=~/.claude/skills

# Workspace path (where OpenSpace stores data) — relative to project root
# This is platform-agnostic and works everywhere as-is
OPENSPACE_WORKSPACE=./tools/openspace

# Cloud API key (optional — enables skill upload/download and cloud search)
OPENSPACE_API_KEY=

# Debug logging (optional)
OPENSPACE_DEBUG=false

# Windows encoding fix — forces UTF-8 mode (fixes checkmark rendering in CLI)
PYTHONUTF8=1

# Ponytail — YAGNI/minimal-code discipline plugin (-54% LOC, -22% tokens, -20% cost)
# Levels: full (default), lite, ultra, off
# Always-on after install. Change level per-session with /ponytail [level]
PONYTAIL_DEFAULT_MODE=full

# Caveman — Token compression (optional statusline badge)
# Shows lifetime token savings in Claude Code statusline
CAVEMAN_STATUSLINE_SAVINGS=1

# Claude-Mem — Persistent memory across sessions (optional mode config)
# Modes: code (default English), code--zh (Simplified Chinese), code--ja (Japanese)
# See: ~/.claude-mem/settings.json (auto-created on first run)
CLAUDE_MEM_MODE=code

# ──────────────────────────────────────────────────────────────────────────────
# MCP SERVER CREDENTIALS
# ──────────────────────────────────────────────────────────────────────────────
# Add MCP server keys here if your application code (Trigger.dev tasks, Python
# tools) needs to call the same services. Otherwise, setting them in
# .claude/settings.local.json only is sufficient.

# Firecrawl API Key — firecrawl.dev/app/api-keys → Create API Key
# Used by: firecrawl-cli (local), firecrawl-mcp (backup for batch/schema extraction)
FIRECRAWL_API_KEY=

# Browser Use API Key — app.browser-use.com → API Keys (optional — only needed for cloud/headless browsers)
# Used by: browser-harness CLI (`browser-harness auth login --api-key-stdin`)
# Local Chrome automation works without this key
BROWSER_USE_API_KEY=

# Groq API Key — console.groq.com → API Keys (optional — used by /watch for Whisper transcription)
# Used by: claude-video plugin when videos lack captions. Set in ~/.config/watch/.env (auto-created)
# OPENAI_API_KEY above is the fallback if this is unset. Native captions work without either.
GROQ_API_KEY=

# Graphify — codebase knowledge graph (optional HTTP MCP server auth only)
# Used by: graphify-mcp HTTP mode only. Local stdio mode (default) needs no key.
# Install: uv tool install 'graphifyy[mcp]', then run: /graphify . inside Claude Code
GRAPHIFY_API_KEY=

# 21st.dev Magic MCP — 21st.dev/magic/console → API Keys. Free tier: Inspiration + Logo Search. Pro: Builder + Refiner.
TWENTYFIRST_DEV_MAGIC_API_KEY=
# 21st.dev Studio CLI — 21st.dev/studio → Settings → API Keys. Used by @21st-dev/cli for publishing components to the registry.
TWENTYFIRST_DEV_CLI_API_KEY=            

# === Supabase ===
# Project URL — Supabase dashboard → Project Settings → API → Project URL
# e.g. https://xyzabc.supabase.co
SUPABASE_PROJECT_URL=
# Service Role Key or Anon Key — Supabase dashboard → Project Settings → API → Project API keys
# Used by: Supabase JS SDK in application code (Trigger.dev tasks, Python tools)
SUPABASE_PROJECT_KEY=

# === OpenRouter ===
OPENROUTER_API_KEY=
# OpenRouter URL
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Model to use (see https://openrouter.ai/models)
# OpenRouter model to use for answer generation (default: auto)
OPENROUTER_MODEL=openrouter/auto                              # OpenRouter Auto (default, balanced performance)
# OPENROUTER_MODEL=openrouter/free                              # OpenRouter Free (free tier, good performance)
# OPENROUTER_MODEL=openai/gpt-4o                                # OpenAI GPT-4 Omni (default, balanced performance)
# OPENROUTER_MODEL=openai/gpt-4o-mini                           # OpenAI GPT-4 Omni Mini (faster, cheaper)
# OPENROUTER_MODEL=anthropic/claude-sonnet-4                    # Claude Sonnet 4 (excellent reasoning)
# OPENROUTER_MODEL=anthropic/claude-sonnet-4-5                  # Claude Sonnet 4.5 (improved reasoning, creativity)
# OPENROUTER_MODEL=anthropic/claude-opus-4                      # Claude Opus 4 (most capable)
# OPENROUTER_MODEL=anthropic/claude-opus-4-5                    # Claude Opus 4.5 (improved reasoning, creativity)
# OPENROUTER_MODEL=google/gemini-2.0-flash-thinking-exp:free    # Google Gemini 2.0 Flash (free tier)
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct            # Llama 3.3 70B Instruct (open model, high performance)
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-chat                # Llama 3.3 70B Chat (open model, chat optimized)
# OPENROUTER_MODEL=deepseek/deepseek-chat                       # DeepSeek Chat (open model, good performance, cost effective)
