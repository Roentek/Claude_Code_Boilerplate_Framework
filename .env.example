# API Keys and Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# === Supabase ===
# Supabase personal access token (MCP)
SUPABASE_API_PAT=""    
# e.g. https://xyzabc.supabase.co
SUPABASE_PROJECT_URL="" 
# anon/service role key from Supabase dashboard                  
SUPABASE_PROJECT_KEY=""                       

# === OpenRouter ===
# OpenRouter URL
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
 # OpenRouter API key (no quotes required)
OPENROUTER_API_KEY=     
# Model to use (see https://openrouter.ai/models)       
# OpenRouter model to use for answer generation (default: auto) 
OPENROUTER_MODEL=openrouter/auto                              # OpenRouter Auto (default, balanced performance)
# OPENROUTER_MODEL=openrouter/free                              # OpenRouter Free (free tier, good performance)
# OPENROUTER_MODEL=openai/gpt-4o                                # OpenAI GPT-4 Omni (default, balanced performance)
# OPENROUTER_MODEL=openai/gpt-4o-mini                           # OpenAI GPT-4 Omni Mini (faster, cheaper)
# OPENROUTER_MODEL=anthropic/claude-sonnet-4                    # Claude Sonnet 4 (excellent reasoning)
# OPENROUTER_MODEL=anthropic/claude-sonnet-4-5                  # Claude Sonnet 4.5 (improved reasoning, creativity)
# OPENROUTER_MODEL=anthropic/claude-opus-4                      # Claude Opus 4 (most capable)
# OPENROUTER_MODEL=anthropic/claude-opus-4-5                    # Claude Opus 4.5 (improved reasoning, creativity)
# OPENROUTER_MODEL=google/gemini-2.0-flash-thinking-exp:free    # Google Gemini 2.0 Flash (free tier)
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct            # Llama 3.3 70B Instruct (open model, high performance)
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-chat                # Llama 3.3 70B Chat (open model, chat optimized)
# OPENROUTER_MODEL=deepseek/deepseek-chat                       # DeepSeek Chat (open model, good performance, cost effective)

# Anthropic models via OpenRouter (Claude Sonnet 4, Claude Opus 4, etc.)
# Add this to the env section of .claude/settings.json to use Anthropic models 
# via OpenRouter in the Claude runtime
# {
#   "permissions": {
#     "env": {
#       "ANTHROPIC_BASE_URL": "${OPENROUTER_BASE_URL}",
#       "ANTHROPIC_AUTH_TOKEN": "${OPENROUTER_API_KEY}",
#       "ANTHROPIC_API_KEY": "",
#       "ANTHROPIC_MODEL": "${OPENROUTER_MODEL}"
#     }
#   }
# }

# === KEI ===
# KEI API key (for KEI MCP server)
KIE_AI_API_KEY=""

# =-== Tavily ===
# Tavily search API key (for Tavily MCP server)
TAVILY_API_KEY=""

# === Google Workspace ===
# Google Workspace MCP uses Google OAuth for authentication, so no API keys are needed in .env
GOOGLE_USER_EMAIL=""
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""

# === Pinecone ===
# Pinecone vector DB API key (for Pinecone MCP server)
PINECONE_API_KEY=""

# === Vapi ===
# Vapi MCP server environment variables
# CLIENTS USE THIS KEY
VAPI_SDK_KEY=""  
# MCP USE THIS TOKEN                                               
VAPI_API_TOKEN=""                                               

# === Alpaca ===
# Alpaca Trading API keys (for Alpaca MCP server)
# Use paper trading API for testing
ALPACA_BASE_URL=""  
ALPACA_API_KEY=""
ALPACA_SECRET_KEY=""

# === n8n ===
# Self hosted n8n MCP server environment variables
N8N_HOST_URL=""
N8N_API_KEY=""

# === Apify ===
# Apify web scraping API token (for Apify MCP server)
APIFY_API_PAT=""

# === Canva ===
# Canva MCP uses browser-based OAuth (no keys needed in .env)
# Authentication happens automatically when the MCP server starts
# The Canva MCP server URL is: https://mcp.canva.com/mcp
# See: https://www.canva.dev/docs/mcp/

# === Monet ===
# Monet MCP server API key (no quotes required)
# see https://www.monet.design/mcp
MONET_API_KEY=